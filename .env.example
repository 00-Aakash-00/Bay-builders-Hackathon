# Copy to .env.local and fill what you have.
# Any missing provider key => that provider runs in mock mode (see worker/tools).

# Claude Agent SDK (orchestrator + subagents)
ANTHROPIC_API_KEY=

# Web data / search
NIMBLE_API_KEY=
TAVILY_API_KEY=
YDC_API_KEY=

# Agent coordination / actions / memory / backend
BAND_AGENT_ID=
BAND_API_KEY=
KYLON_PAK_KEY=
HYDRA_DB_API_KEY=
INSFORGE_BASE_URL=
INSFORGE_API_KEY=

# Engine
WORKER_PORT=8787
# force full mock pipeline regardless of keys (demo insurance)
MOCK_MODE=
